# cp .env.example .env
#
# drm_hls_migration_worker.py (and run_merge / run_zip_merge / run_hls_merge → same worker).
#
# Dependencies live in the project venv (see setup_ec2.sh). Run the worker with:
#   source .venv/bin/activate && python3 drm_hls_migration_worker.py
#   ./.venv/bin/python3 drm_hls_migration_worker.py

# --- API base (pick ONE style) ---
# EDMINGLE_WORKER_API_BASE=http://localhost/nuSource/api/v1
EDMINGLE_API_PROTOCOL=http
EDMINGLE_API_HOST=localhost
EDMINGLE_API_PATH_PREFIX=/nuSource/api/v1

APIKEY=
ORGID=

DRM_MIGRATION_INSTITUTION_ID=0
# Seconds to sleep after each job (success or failure) before calling worker/next again (default 1.5).
# DRM_MIGRATION_JOB_GAP_SEC=1.5
# Merge after worker/next: hls (ffmpeg HLS master from job) | zip (Storage ZIP for zone + drm_id from job)
DRM_MIGRATION_MERGE_METHOD=hls

# Only used when drm_migration_s3_* IAM keys are unset (fallback MP4 save).
DRM_MIGRATION_LOCAL_OUTPUT_DIR=./drm_migration_output

drm_migration_s3_bucket_name=
drm_migration_s3_region=us-east-1
drm_migration_s3_access_key=
drm_migration_s3_secret_key=

#
# Legacy only: bunny_stream_hls_merge_to_mp4.py needs --library-id, --access-key, --cdn-base,
# --video-guid on the CLI (no Bunny creds in .env for the Edmingle worker; those come from worker/next).
